{
	"name": "@selemondev/vue3-signature-pad",
	"type": "module",
	"version": "1.7.0",
	"private": false,
	"packageManager": "pnpm@9.15.9",
	"description": "Vue 3 based smooth signature drawing component ✨",
	"author": "Selemondev",
	"homepage": "https://github.com/selemondev/vue3-signature-pad#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/selemondev/vue3-signature-pad.git"
	},
	"bugs": {
		"url": "https://github.com/selemondev/vue3-signature-pad/issues"
	},
	"sideEffects": false,
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"build:site": "pnpm --filter www build",
		"build:dts": "vue-tsc --declaration --emitDeclarationOnly",
		"dev:lib": "tsdown --watch ./src/index.ts",
		"dev:site": "pnpm --filter www dev",
		"lint": "biome format --write",
		"generate:release": "pnpx changelogen@latest --release",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@astrojs/react": "^4.4.2",
		"@astrojs/vercel": "^9.0.2",
		"@astrojs/vue": "^5.1.3",
		"@biomejs/biome": "2.3.8",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-direction": "^1.1.1",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slider": "^1.3.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vue/tsconfig": "^0.7.0",
		"astro": "^5.16.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"hastscript": "^9.0.1",
		"lucide-react": "^0.562.0",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"reka-ui": "^2.6.1",
		"signature_pad": "^5.1.3",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.18",
		"tsdown": "^0.16.8",
		"typescript": "~5.9.3",
		"unplugin-vue": "^5.2.1",
		"vue": "^3.5.25",
		"vue-tsc": "^3.1.8"
	},
	"devDependencies": {
		"shiki": "^3.20.0"
	}
}
