{
  "name": "@selemondev/vue3-signature-pad",
  "type": "module",
  "version": "1.6.4",
  "private": false,
  "packageManager": "pnpm@9.15.9",
  "description": "Vue 3 based smooth signature drawing component ✨",
  "author": "Selemondev",
  "homepage": "https://github.com/selemondev/vue3-signature-pad#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/selemondev/vue3-signature-pad.git"
  },
  "bugs": {
    "url": "https://github.com/selemondev/vue3-signature-pad/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:dts": "vue-tsc --declaration --emitDeclarationOnly",
    "dev:lib": "tsdown --watch ./src/index.ts",
    "dev:site": "pnpm --filter website dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate:release": "pnpx changelogen@latest --release",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "dependencies": {
    "signature_pad": "^5.1.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.39.1",
    "tsdown": "^0.16.8",
    "typescript": "~5.9.3",
    "unplugin-vue": "^5.2.1",
    "vue": "^3.5.25",
    "vue-tsc": "^3.1.8"
  }
}
