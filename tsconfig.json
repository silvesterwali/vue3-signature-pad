{
	"extends": ["./tsconfig.base.json"],
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"]
		},
		"allowImportingTsExtensions": true,
		"declaration": true,
		"declarationDir": "./dist",
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"isolatedModules": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.tsx",
		"src/**/*.vue",
		"env.d.ts",
		".astro/types.d.ts",
		"**/*"
	],
	"exclude": ["www", "dist"]
}
